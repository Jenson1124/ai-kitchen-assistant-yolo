{
  "expo": {
    "name": "EzuraSense",
    "slug": "EzuraSense",
    "scheme": "ezura-sense",
    "deeplink": "my-ezura-home",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/EZURA_LOGO.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/EZURA_LOGO.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/EZURA_LOGO.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ]
  }
}
